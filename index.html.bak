<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>你什么咖？ | Y2K Cyber-Cup Scanner</title>
    <!-- 引入 face-api.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <!-- 引入 html2canvas 用于截图 -->
    <script defer src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <!-- 引入卡通模板 -->
    <script defer src="templates.js"></script>
    <style>
        /* Y2K 极简风设计基础 */
        :root {
            --bg-color: #f0f0f0;
            --text-color: #111111;
            --accent-pink: #ff00ff;
            --accent-blue: #00ffff;
            --border-radius: 12px;
            --border-thick: 3px solid black;
            --shadow: 6px 6px 0px #000;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Courier New', monospace;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            padding: 20px;
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.4;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: var(--border-thick);
            padding-bottom: 15px;
        }

        h1 {
            font-size: 2.2rem;
            font-weight: 900;
            letter-spacing: -1px;
            margin-bottom: 5px;
            color: var(--text-color);
        }

        .subtitle {
            font-size: 0.9rem;
            color: #666;
            margin-bottom: 10px;
        }

        .status-bar {
            background: black;
            color: #0f0;
            padding: 8px 12px;
            border-radius: 6px;
            font-family: monospace;
            margin-bottom: 20px;
            border: 2px solid #0f0;
            text-align: center;
            min-height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .video-container {
            position: relative;
            width: 100%;
            max-width: 400px;
            margin: 0 auto 30px;
            border: var(--border-thick);
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--shadow);
            background: black;
        }

        #video {
            width: 100%;
            display: block;
            transform: scaleX(-1); /* 镜像翻转 */
        }

        .crosshair {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            pointer-events: none;
        }

        .crosshair::before, .crosshair::after {
            content: '';
            position: absolute;
            background: var(--accent-pink);
        }

        .crosshair::before {
            top: 10px; left: 10px; right: 10px; height: 2px;
        }

        .crosshair::after {
            left: 10px; top: 10px; bottom: 10px; width: 2px;
        }

        .button {
            display: block;
            width: 100%;
            padding: 18px;
            background: black;
            color: white;
            border: var(--border-thick);
            border-radius: var(--border-radius);
            font-size: 1.2rem;
            font-weight: bold;
            text-align: center;
            cursor: pointer;
            margin-bottom: 15px;
            transition: all 0.1s;
            box-shadow: var(--shadow);
            user-select: none;
        }

        .button:active {
            transform: translate(3px, 3px);
            box-shadow: 3px 3px 0px #000;
        }

        .button.primary {
            background: var(--accent-pink);
            color: black;
        }

        .result-card {
            display: none;
            border: var(--border-thick);
            border-radius: var(--border-radius);
            padding: 25px;
            margin-top: 30px;
            background: white;
            box-shadow: var(--shadow);
            position: relative;
        }

        .stamp {
            position: absolute;
            top: -20px;
            right: -20px;
            width: 120px;
            height: 120px;
            background: var(--accent-pink);
            color: black;
            border: 4px solid black;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            font-weight: 900;
            transform: rotate(15deg);
            z-index: 10;
        }

        .result-image {
            width: 100%;
            border: 2px solid black;
            border-radius: 8px;
            margin: 15px 0;
        }

        .disclaimer {
            font-size: 0.8rem;
            color: #666;
            text-align: center;
            margin-top: 30px;
            padding-top: 15px;
            border-top: 1px dashed #ccc;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>你什么咖？</h1>
        <div class="subtitle">Y2K Cyber-Cup Scanner</div>
        <div class="subtitle">已为 34,102 名用户测出真实咖位</div>
    </div>

    <div class="status-bar" id="statusText">
        INITIALIZING...
    </div>

    <div class="video-container">
        <video id="video" autoplay playsinline></video>
        <div class="crosshair"></div>
    </div>

    <button class="button primary" id="scanButton" disabled>
        长按扫描你的咖位
    </button>

    <div class="result-card" id="resultCard">
        <div class="stamp" id="stampText">B咖</div>
        <h2>赛博成分鉴定报告</h2>
        <img id="resultImage" class="result-image" alt="抓拍表情">
        <div id="resultText">
            <p>系统正在分析中...</p>
        </div>
        <button class="button" id="saveButton">
            长按保存图片 炫耀你的咖位
        </button>
        <button class="button" id="retryButton">
            不服？重测一次
        </button>
    </div>

    <div class="disclaimer">
        ⚠️ 纯本地运算，不上传任何照片，保护隐私<br>
        🎭 仅供娱乐，请勿当真
    </div>

    <script>
        // DOM 元素
        const statusText = document.getElementById('statusText');
        const video = document.getElementById('video');
        const scanButton = document.getElementById('scanButton');
        const resultCard = document.getElementById('resultCard');
        const resultImage = document.getElementById('resultImage');
        const resultText = document.getElementById('resultText');
        const stampText = document.getElementById('stampText');
        const saveButton = document.getElementById('saveButton');
        const retryButton = document.getElementById('retryButton');

        let modelsLoaded = false;
        let cameraReady = false;
        let isScanning = false;
        let pressTimer = null;
        let capturedImage = null;

        // 咖位映射表
        const CUP_MAP = {
            'A': { cup: 'A咖', text: '骨相修长，脂肪绝缘体。坦坦荡荡的 A 咖，平胸骄傲，为你点赞！' },
            'B': { cup: 'B咖', text: '长宽比处于黄金分割的暧昧地带。进可攻退可守，薛定谔的 B 咖。多吃一口长脸上，少吃一口掉胸上。' },
            'C': { cup: 'C咖', text: '脸庞略宽，胶原蛋白走位极其精准。根据《圆脸引力假说》，下沉的脂肪完美支撑起了 C 咖的尊严。' },
            'D': { cup: 'D咖', text: '横向发展面相，大脸盘子实锤！但这绝对是值得骄傲的。大脸 = 大基数 = 灭世 D 咖！胸怀天下，恐怖如斯。' }
        };

        // 1. 加载 face-api 模型
        async function loadModels() {
            statusText.innerText = "LOADING AI MODELS [■■■□□]";
            const MODEL_URL = './models';
            try {
                await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
                modelsLoaded = true;
                statusText.innerText = "MODELS LOADED [■■■■■]";
                console.log('✓ Models loaded successfully');
                initCamera();
            } catch (e) {
                statusText.innerText = "ERR: MODEL LOAD FAILED";
                console.error('Model load error:', e);
                scanButton.innerText = "模型加载失败，请刷新页面";
            }
        }

        // 2. 初始化摄像头（但不立即打开）
        async function initCamera() {
            statusText.innerText = "READY FOR CAMERA [■■■■□]";
            scanButton.disabled = false;
            scanButton.innerText = "点击开启摄像头";
            
            scanButton.onclick = async () => {
                if (!cameraReady) {
                    await startCamera();
                }
            };
        }

        // 3. 启动摄像头
        async function startCamera() {
            statusText.innerText = "ACCESSING CAM [■■■■□]";
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: 'user', width: 400, height: 533 } 
                });
                video.srcObject = stream;
                cameraReady = true;
                statusText.innerText = "CAMERA READY [■■■■■]";
                scanButton.innerText = "长按扫描你的咖位";
                
                // 设置长按事件
                setupScanButton();
                
            } catch (e) {
                statusText.innerText = "ERR: CAMERA ACCESS DENIED";
                console.error('Camera error:', e);
                scanButton.innerText = "摄像头权限被拒绝，请刷新重试";
            }
        }

        // 4. 设置扫描按钮事件
        function setupScanButton() {
            scanButton.onmousedown = scanButton.ontouchstart = (e) => {
                e.preventDefault();
                if (isScanning) return;
                
                isScanning = true;
                statusText.innerText = "SCANNING... [█▒▒▒▒]";
                
                pressTimer = setTimeout(() => {
                    captureAndAnalyze();
                }, 1000); // 长按1秒
            };

            scanButton.onmouseup = scanButton.ontouchend = scanButton.onmouseleave = (e) => {
                e.preventDefault();
                if (pressTimer) {
                    clearTimeout(pressTimer);
                    pressTimer = null;
                }
                if (isScanning) {
                    isScanning = false;
                    statusText.innerText = "CAMERA READY [■■■■■]";
                }
            };
        }

        // 5. 捕获并分析
        async function captureAndAnalyze() {
            if (!modelsLoaded || !cameraReady) return;
            
            statusText.innerText = "ANALYZING... [██▒▒▒]";
            
            // 捕获当前帧
            const canvas = document.createElement('canvas');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(video, 0, 0);
            
            // 镜像翻转回来
            ctx.scale(-1, 1);
            ctx.drawImage(video, -canvas.width, 0);
            ctx.setTransform(1, 0, 0, 1, 0, 0);
            
            capturedImage = canvas.toDataURL('image/jpeg');
            resultImage.src = capturedImage;
            
            // 使用 face-api 检测人脸
            try {
                const detections = await faceapi.detectAllFaces(video, new faceapi.TinyFaceDetectorOptions());
                
                if (detections.length === 0) {
                    showResult('A', "系统未检测到人脸。可能你离得太远，或者脸太小了。默认判定为：坦荡 A 咖！");
                    return;
                }
                
                const face = detections[0];
                const box = face.box;
                
                // 计算长宽比
                const ratio = box.width / box.height;
                
                // 根据长宽比判定咖位
                let cupType = 'A';
                if (ratio < 0.73) cupType = 'A';
                else if (ratio < 0.78) cupType = 'B';
                else if (ratio < 0.85) cupType = 'C';
                else cupType = 'D';
                
                showResult(cupType, `面部长宽比: ${ratio.toFixed(2)}`);
                
            } catch (e) {
                console.error('Face detection error:', e);
                // 如果检测失败，随机给一个结果
                const randomCup = ['A', 'B', 'C', 'D'][Math.floor(Math.random() * 4)];
                showResult(randomCup, "系统分析出现波动，但依然给出了鉴定结果！");
            }
        }

        // 6. 显示结果
        function showResult(cupType, analysisNote) {
            const cupInfo = CUP_MAP[cupType];
            stampText.innerText = cupInfo.cup;
            
            resultText.innerHTML = `
                <h3>${cupInfo.cup} - ${cupType.toUpperCase()} Cup</h3>
                <p>${cupInfo.text}</p>
                <p><small>${analysisNote}</small></p>
                <p>⚠️ 本结果基于《面部-胸部能量守恒定律》计算，仅供娱乐。</p>
            `;
            
            resultCard.style.display = 'block';
            statusText.innerText = "ANALYSIS COMPLETE [█████]";
            isScanning = false;
            
            // 滚动到结果
            resultCard.scrollIntoView({ behavior: 'smooth' });
        }

        // 7. 保存图片
        saveButton.onclick = async () => {
            statusText.innerText = "SAVING IMAGE...";
            try {
                const canvas = await html2canvas(resultCard);
                const link = document.createElement('a');
                link.download = `你什么咖-${stampText.innerText}.png`;
                link.href = canvas.toDataURL('image/png');
                link.click();
                statusText.innerText = "IMAGE SAVED!";
            } catch (e) {
                console.error('Save error:', e);
                statusText.innerText = "SAVE FAILED";
            }
        };

        // 8. 重试
        retryButton.onclick = () => {
            resultCard.style.display = 'none';
            statusText.innerText = "CAMERA READY [■■■■■]";
        };

        // 页面加载完成后启动
        window.addEventListener('DOMContentLoaded', () => {
            loadModels();
        });
    </script>
</body>
</html>
